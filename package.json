{
    "private": true,
    "scripts": {
        "dev": "npm run development",
        "development": "cross-env NODE_OPTIONS=--max-old-space-size=4096 mix",
        "watch": "cross-env NODE_OPTIONS=--max-old-space-size=4096 mix watch",
        "watch-poll": "mix watch -- --watch-options-poll=1000",
        "hot": "mix watch --hot",
